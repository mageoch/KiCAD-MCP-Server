{
  "mcpServers": {
    "kicad_helper": {
      "command": "uv",
      "args": ["--directory", "/path/to/KiCAD-MCP-Server", "run", "python", "python/kicad_interface.py"],
      "env": {
        "PYTHONPATH": "/usr/lib/kicad/lib/python3/dist-packages"
      },
      "description": "KiCAD PCB Design Assistant"
    }
  }
}
